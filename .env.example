POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=iitr-db-test
EARLIEST_START_DATE=01-01-2025

# --- Local file storage (LocalFileStorage) ---
STORAGE_DIR=D:\Workspace\STORAGE

# --- AWS S3 storage (AwsFileStorage) ---
# Target bucket name (required when using AwsFileStorage)
AWS_S3_BUCKET=ledger-lens-documents
# Bucket region, e.g. ap-south-1 (Mumbai), us-east-1
AWS_REGION=ap-south-1
# Optional key prefix applied to every uploaded object (acts like a root folder)
AWS_S3_PREFIX=nse
# IAM credentials. Leave blank to use the default AWS credential chain
# (shared ~/.aws/credentials profile, EC2/ECS instance role, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed for temporary/STS credentials
AWS_SESSION_TOKEN=
# Only set for S3-compatible stores (MinIO/LocalStack); leave blank for real AWS
AWS_S3_ENDPOINT_URL=