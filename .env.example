POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=iitr-db-test
EARLIEST_START_DATE=01-01-2025

# Base URL of the external RAG service that ingests stored files
RAG_API_BASE_URL=http://localhost:8080

# Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins. Defaults to "*" (any origin).
# A wildcard "*" cannot be combined with credentialed (cookie) requests, so
# credentials are only enabled when explicit origins are listed.
# Example: CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=*

# --- Local file storage (LocalFileStorage) ---
STORAGE_DIR=D:\Workspace\STORAGE

# --- AWS S3 storage (AwsFileStorage) ---
# Target bucket name (required when using AwsFileStorage)
AWS_S3_BUCKET=ledger-lens-documents
# Bucket region, e.g. ap-south-1 (Mumbai), us-east-1
AWS_REGION=ap-south-1
# Optional key prefix applied to every uploaded object (acts like a root folder)
AWS_S3_PREFIX=nse
# IAM credentials. Leave blank to use the default AWS credential chain
# (shared ~/.aws/credentials profile, EC2/ECS instance role, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed for temporary/STS credentials
AWS_SESSION_TOKEN=
# Only set for S3-compatible stores (MinIO/LocalStack); leave blank for real AWS
AWS_S3_ENDPOINT_URL=